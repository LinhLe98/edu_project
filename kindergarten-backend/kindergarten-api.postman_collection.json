    {
      "name": "Contact",
      "item": [
        {
          "name": "Get contact info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contact",
              "host": ["{{baseUrl}}"],
              "path": ["contact"]
            }
          }
        },
        {
          "name": "Submit support request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"phone\": \"0901234567\",\n  \"email\": \"parent@example.com\",\n  \"subject\": \"Hỏi về lịch học\",\n  \"message\": \"Cho tôi hỏi lịch học tuần tới của lớp 3 tuổi như thế nào?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/contact/support-requests",
              "host": ["{{baseUrl}}"],
              "path": ["contact", "support-requests"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get support requests",
          "request": {
            "method": "GET",
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{adminUsername}}", "type": "string" },
                { "key": "password", "value": "{{adminPassword}}", "type": "string" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/admin/support-requests?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "support-requests"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    }
  ]
}
