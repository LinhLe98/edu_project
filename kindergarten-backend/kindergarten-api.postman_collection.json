{
  "info": {
    "name": "Kindergarten Backend API",
    "description": "REST API for Trường Mầm Non Ánh Dương. Base URL: http://localhost:8080/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "adminUsername",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "admin",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Slides",
      "item": [
        {
          "name": "Get all slides",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/slides",
              "host": ["{{baseUrl}}"],
              "path": ["slides"]
            }
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Get all staff",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff",
              "host": ["{{baseUrl}}"],
              "path": ["staff"]
            }
          }
        },
        {
          "name": "Get featured staff",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/featured",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "featured"]
            }
          }
        },
        {
          "name": "Get management team",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/management",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "management"]
            }
          }
        },
        {
          "name": "Get all teachers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/teachers",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "teachers"]
            }
          }
        },
        {
          "name": "Get staff by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/:id",
              "host": ["{{baseUrl}}"],
              "path": ["staff", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get staff by department",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/department/:dept",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "department", ":dept"],
              "variable": [
                {
                  "key": "dept",
                  "value": "ban-giam-hieu",
                  "description": "ban-giam-hieu | to-giao-vien-la | to-giao-vien-choi | to-giao-vien-mam | to-nhan-vien"
                }
              ]
            }
          }
        },
        {
          "name": "Get department leader",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/department/:dept/leader",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "department", ":dept", "leader"],
              "variable": [
                {
                  "key": "dept",
                  "value": "ban-giam-hieu",
                  "description": "ban-giam-hieu | to-giao-vien-la | to-giao-vien-choi | to-giao-vien-mam | to-nhan-vien"
                }
              ]
            }
          }
        },
        {
          "name": "Get department vice-leaders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/staff/department/:dept/vice-leaders",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "department", ":dept", "vice-leaders"],
              "variable": [
                {
                  "key": "dept",
                  "value": "ban-giam-hieu",
                  "description": "ban-giam-hieu | to-giao-vien-la | to-giao-vien-choi | to-giao-vien-mam | to-nhan-vien"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "News",
      "item": [
        {
          "name": "Get paginated news",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/news?page=0&size=6",
              "host": ["{{baseUrl}}"],
              "path": ["news"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "6" }
              ]
            }
          }
        },
        {
          "name": "Get featured news",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/news/featured",
              "host": ["{{baseUrl}}"],
              "path": ["news", "featured"]
            }
          }
        },
        {
          "name": "Get latest news",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/news/latest?count=3",
              "host": ["{{baseUrl}}"],
              "path": ["news", "latest"],
              "query": [
                { "key": "count", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "Get news by category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/news/category/:category",
              "host": ["{{baseUrl}}"],
              "path": ["news", "category", ":category"],
              "variable": [
                {
                  "key": "category",
                  "value": "su-kien",
                  "description": "thong-bao | su-kien | tin-tuc | hoat-dong"
                }
              ]
            }
          }
        },
        {
          "name": "Get news by slug",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/news/:slug",
              "host": ["{{baseUrl}}"],
              "path": ["news", ":slug"],
              "variable": [
                {
                  "key": "slug",
                  "value": ""
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Programs",
